#CODE
#include <Wire.h>
#include <U8g2lib.h>
#include "DHT.h"

// OLED (same as tera code)
U8G2_SH1106_128X64_NONAME_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE);

// DHT11
#define DHTPIN 4
#define DHTTYPE DHT11
DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Wire.begin(21, 22);  // SDA, SCL
  u8g2.begin();
  dht.begin();
}

void loop() {

  // 🔹 Screen 1: Intro
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB14_tr);
  u8g2.drawStr(15, 35, "nexo ^_^");
  u8g2.sendBuffer();
  delay(2000);

  // 🔹 Screen 2: Temperature
  float temp = dht.readTemperature();
  float hum = dht.readHumidity();

  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);

  u8g2.drawStr(0, 12, "Temperature:");
  
  char t[20];
  sprintf(t, "%.1f C", temp);
  u8g2.setFont(u8g2_font_fub14_tr);
  u8g2.drawStr(20, 35, t);

  u8g2.setFont(u8g2_font_5x8_tr);
  u8g2.drawStr(0, 60, "Range: 0-50C  Acc: +-2C");

  u8g2.sendBuffer();
  delay(3000);

  // 🔹 Screen 3: Humidity
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_ncenB08_tr);

  u8g2.drawStr(0, 12, "Humidity:");

  char h[20];
  sprintf(h, "%.1f %%", hum);
  u8g2.setFont(u8g2_font_fub14_tr);
  u8g2.drawStr(20, 35, h);

  u8g2.setFont(u8g2_font_5x8_tr);
  u8g2.drawStr(0, 60, "Range:20-90% Acc:+-5%");

  u8g2.sendBuffer();
  delay(3000);
}
